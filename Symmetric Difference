# 1. Read input for Set M
m_size = int(input())
m_set = set(map(int, input().split()))

# 2. Read input for Set N
n_size = int(input())
n_set = set(map(int, input().split()))

# 3. Calculate symmetric difference
# This finds elements in M or N, but not both
sym_diff = m_set.symmetric_difference(n_set)

# 4. Sort and print result one per line
for value in sorted(sym_diff):
    print(value)
