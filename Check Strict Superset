# Read the main set A
storage = set(map(int, input().split()))

# Read the number of other sets
n = int(input())

# Initialize a flag to track if A is a strict superset of all sets
is_strict_superset = True

for _ in range(n):
    # Read the next set
    other_set = set(map(int, input().split()))
    
    # Check if storage is a strict superset of other_set
    # The '>' operator checks for a strict superset
    if not (storage > other_set):
        is_strict_superset = False
        break

print(is_strict_superset)

