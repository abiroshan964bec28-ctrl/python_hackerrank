def print_formatted(number):
    decimal = []
    octal = []
    hexadecimal = []
    binary = []
    for i in range(number):
        decimal.append(i + 1)
        octal.append(decimal_to_octal(i + 1))
        hexadecimal.append((decimal_to_hexadecimal(i + 1)))
        binary.append(decimal_to_binary(i + 1))
    space = len(str(decimal_to_binary(number)))
    
    for i in range(number):
        print(f"{decimal[i]:>{space}} {octal[i]:>{space}} {hexadecimal[i]:>{space}} {binary[i]:>{space}}")

