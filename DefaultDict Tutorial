from collections import defaultdict

# 1. Read n and m
n, m = map(int, input().split())

# 2. Initialize defaultdict with a list factory
d = defaultdict(list)

# 3. Read Group A words and store their 1-indexed positions
for i in range(1, n + 1):
    word = input().strip()
    d[word].append(str(i))

# 4. Read Group B words and print positions or -1
for _ in range(m):
    word_b = input().strip()
    if word_b in d:
        # Join the list of indices with spaces
        print(" ".join(d[word_b]))
    else:
        print("-1")
