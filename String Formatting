
# 3 ham chuyen ve octal, hexadecimal, binary
def decimal_to_octal(decimal):
    key = []
    while decimal != 0:
        key.append(str(decimal %8))
        decimal = decimal //8
    key = key[::-1]
    return "".join(key)

def decimal_to_hexadecimal(decimal):
    key = []
    while decimal != 0:
        if decimal %16 == 10:
            key.append("A")
        elif decimal %16 == 11:
            key.append("B")
        elif decimal %16 == 12:
            key.append("C")
        elif decimal %16 == 13:
            key.append("D")
        elif decimal %16 == 14:
            key.append("E")
        elif decimal %16 == 15:
            key.append("F")
        else:
            key.append(str(decimal %16))
        decimal = decimal //16
    key = key[::-1]
    return "".join(key)

def decimal_to_binary(decimal):
    key = []
    while decimal != 0:
        key.append(str(decimal %2))
        decimal = decimal //2
    key = key[::-1]
    return "".join(key)
    
