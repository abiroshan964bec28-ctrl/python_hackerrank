s = input()

# Custom sorting key logic:
# 1. Lowercase letters (islower) -> lowest weight
# 2. Uppercase letters (isupper) -> medium-low weight
# 3. Odd digits -> medium-high weight
# 4. Even digits -> highest weight

def sort_key(c):
    if c.islower():
        return (0, c)
    elif c.isupper():
        return (1, c)
    elif c.isdigit():
        if int(c) % 2 != 0:
            return (2, c) # Odd digits
        else:
            return (3, c) # Even digits

# Apply sorting and join characters back into a string
result = sorted(s, key=sort_key)
print("".join(result))
